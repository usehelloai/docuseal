<section class="flex items-center justify-center">
  <div class="py-10 mx-auto max-w-7xl w-full">
    <div class="max-w-xl mx-auto px-4">
      <div class="text-center">
        <div class="relative flex flex-col items-center">
          <%= render 'shared/logo', width: '60', height: '60' %>
          <h1 class="font-bold mt-4 mb-4" style="font-size: 44px">
            Hello AI
          </h1>
          <% if Docuseal.version.present? %>
            <a href="https://github.com/docusealco/docuseal/releases" target="_blank" class="badge badge-outline badge-lg block mx-auto">
              v<%= Docuseal.version %>
            </a>
          <% end %>
        </div>
        <h2 class="mt-4 mb-16 text-base sm:text-lg text-center text-gray-600 px-2">
          Secure digital document signing for Hello AI. Send, review, and collect signatures on any document in minutes.
        </h2>
      </div>
    </div>
  </div>
</section>
<%= render 'shared/attribution', with_counter: false %>
